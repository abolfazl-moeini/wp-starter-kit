{
  "name": "@wpdev/build",
  "version": "0.1.0",
  "description": "esbuild-based build pipeline for wp-starter-kit consumers (components, dependencies, styles, assets).",
  "type": "module",
  "main": "index.js",
  "bin": {
    "wpdev-build-dependencies": "./esbuild-dependencies-cli.js",
    "wpdev-build-components": "./esbuild-components-cli.js",
    "wpdev-build-styles": "./esbuild-styles-cli.js",
    "wpdev-build-assets": "./build-assets-cli.js",
    "wpdev-check": "./wpdev-check-cli.js"
  },
  "exports": {
    ".": "./index.js",
    "./esbuild-components.js": "./esbuild-components.js",
    "./esbuild-dependencies.js": "./esbuild-dependencies.js",
    "./esbuild-styles.js": "./esbuild-styles.js",
    "./build-assets.js": "./build-assets.js",
    "./getJsxOptions.js": "./getJsxOptions.js"
  },
  "files": [
    "index.js",
    "getJsxOptions.js",
    "esbuild-components.js",
    "esbuild-components-cli.js",
    "esbuild-dependencies.js",
    "esbuild-dependencies-cli.js",
    "esbuild-styles.js",
    "esbuild-styles-cli.js",
    "build-assets.js",
    "build-assets-cli.js",
    "wpdev-check-cli.js",
    "build-all.js"
  ],
  "dependencies": {
    "@wpdev/dependency-extraction-esbuild-plugin": "^1.0.0",
    "@core/utils": "^0.1.0",
    "chalk": "^5.4.1",
    "esbuild": "^0.20.2",
    "yargs": "^17.7.2"
  },
  "license": "MIT"
}
