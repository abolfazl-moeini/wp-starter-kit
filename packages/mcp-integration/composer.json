{
  "name": "wpdev/mcp-integration",
  "description": "Self-contained WordPress Abilities API integration: register abilities that the MCP Adapter can expose to AI agents as MCP tools.",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "abilities-api",
    "mcp",
    "ai"
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "WPDev\\MCP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPDev\\MCP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
