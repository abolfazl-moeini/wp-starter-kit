<?xml version="1.0"?>
<ruleset name="wp-starter-kit">
    <description>PHP Version Compatibility and WordPress Coding Standards</description>
    <arg name="extensions" value="php"/>
    <arg name="cache"/>
    <ini name="memory_limit" value="256M"/>
    <arg name="basepath" value="./"/>
    <arg name="parallel" value="10"/>
    <arg value="ps"/>
    <arg name="colors"/>
    <file>.</file>
    <config name="minimum_supported_wp_version" value="6.4"/>
    <config name="testVersion" value="7.4-"/>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>dist/*</exclude-pattern>
    <exclude-pattern>wpdev-starter.php</exclude-pattern>
    <exclude-pattern>packages/php-fault-tolerance/*</exclude-pattern>
    <exclude-pattern>assets/*</exclude-pattern>
    <exclude-pattern>packages/wpdev-framework/*</exclude-pattern>
    <!--
        Dev tooling (rector configs, dev scripts, php-test-tools), tests,
        and the new PSR-4 src/ tree follow their own conventions
        (PSR-12 + tabs not enforced, StudlyCase class names matching
        filename) — only WordPress runtime code under `includes/` is
        gated by full WPCS. The src/ tree was added in p11-autoload and
        expanded in p11-core-classes + p11-assets-support; the same
        "follow their own conventions" rule that was already in place
        for tests/ and dev/ now applies to src/.
    -->
    <exclude-pattern>dev/*</exclude-pattern>
    <exclude-pattern>packages/php-test-tools/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>
    <exclude-pattern>src/*</exclude-pattern>
    <rule ref="PHPCompatibility"/>
    <rule ref="WordPress/"/>
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Extra"/>
    <rule ref="Squiz.Commenting.FileComment.Missing"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="Generic.WhiteSpace.ArbitraryParenthesesSpacing.SpaceAfterOpen"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="Generic.WhiteSpace.ArbitraryParenthesesSpacing.SpaceBeforeClose"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="WordPress.WhiteSpace.ControlStructureSpacing.NoSpaceAfterOpenParenthesis"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="WordPress.WhiteSpace.ControlStructureSpacing.NoSpaceBeforeCloseParenthesis"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="Squiz.Commenting.FileComment.WrongStyle"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="Squiz.Commenting.FunctionComment.Missing"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="PSR2.Files.ClosingTag.NotAllowed"><exclude-pattern>*</exclude-pattern></rule>
    <rule ref="Generic.Arrays.DisallowShortArraySyntax.Found"><severity>0</severity></rule>
    <rule ref="Universal.Arrays.DisallowShortArraySyntax.Found"><severity>0</severity></rule>
    <rule ref="Generic.Arrays.DisallowLongArraySyntax.Found"/>
</ruleset>
