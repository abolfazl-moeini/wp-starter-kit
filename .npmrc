# wp-starter-kit local dev — npm has no Composer-style path repositories.
# Unpublished @wpdev/* packages resolve via:
#   1. workspaces (package.json) — primary for this monorepo
#   2. overrides with file: paths (package.json) — fallback when registry misses
#   3. npm link (global) — for scaffolded consumers outside the repo
#      Run once: npm run dev:setup-local-deps
#
# Global pointer (written to ~/.npmrc by dev/setup-local-deps.mjs):
#   grep wpdev-kit-root ~/.npmrc

install-links=true
