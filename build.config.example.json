{
  "assetMappings": [
    {
      "source": "node_modules/tabulator-tables/dist",
      "destination": "assets/libraries/tabulator",
      "options": { "overwrite": true }
    },
    {
      "source": "node_modules/vanillajs-datepicker/dist/css",
      "destination": "assets/libraries/vanillajs-datepicker/css"
    }
  ],
  "globalMappings": {
    "tabulator-tables": "WPDev.table"
  },
  "styleEntryPoints": ["assets/stylesheets/style.css"]
}
