parameters:
    level: 5
    phpVersion: 80100
    paths:
        - .
    excludePaths:
        - vendor/*
        - dev/*
        - assets/*
        - node_modules/*
        - dist/*
        # Vendored third-party framework — analysed upstream, not in kit CI.
        - packages/wpdev-framework/*
        - tests/*
        - wp-content/*
        - blockstudio/*
        - packages/*/vendor/*
        - core/packages/*/vendor/*
        - packages/mcp-integration/tests/*
        - packages/php-fault-tolerance/tests/*



